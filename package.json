{
   "name": "portfolio-react",
   "version": "3.15.0",
   "type": "module",
   "private": true,
   "homepage": "https://sagargupta.online/portfolio-react/",
   "scripts": {
      "dev": "vite",
      "build": "vite build",
      "preview": "vite preview",
      "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
      "lint:fix": "eslint . --fix",
      "format": "prettier . --write",
      "format:check": "prettier . --check",
      "test": "vitest run",
      "type-check": "tsc --noEmit",
      "predeploy": "pnpm run build",
      "deploy": "gh-pages -d build",
      "clean": "rimraf build node_modules/.vite"
   },
   "dependencies": {
      "@emailjs/browser": "^4.4.1",
      "@fontsource-variable/inter": "^5.2.8",
      "@fontsource-variable/jetbrains-mono": "^5.2.8",
      "@react-three/drei": "^10.7.7",
      "@react-three/fiber": "^9.6.1",
      "@tailwindcss/vite": "^4.3.1",
      "lenis": "^1.3.25",
      "lucide-react": "^1.21.0",
      "motion": "^12.42.0",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "react-github-calendar": "^5.0.6",
      "react-icons": "^5.6.0",
      "react-intersection-observer": "^10.0.3",
      "tailwindcss": "^4.3.1",
      "three": "^0.185.0"
   },
   "devDependencies": {
      "@eslint/js": "^9.39.1",
      "@testing-library/react": "^16.3.2",
      "@types/react-dom": "^19.2.3",
      "@vitejs/plugin-react": "^5.1.4",
      "eslint": "^9.39.4",
      "eslint-plugin-jsx-a11y": "^6.10.2",
      "eslint-plugin-react": "^7.37.5",
      "eslint-plugin-react-hooks": "^7.1.1",
      "eslint-plugin-react-refresh": "^0.5.3",
      "gh-pages": "^6.3.0",
      "globals": "^17.7.0",
      "jsdom": "^29.1.1",
      "prettier": "^3.9.1",
      "rimraf": "^6.1.3",
      "typescript": "^5.9.3",
      "typescript-eslint": "^8.62.0",
      "vite": "^7.3.2",
      "vitest": "^4.1.9"
   },
   "engines": {
      "node": ">=24.11.0",
      "pnpm": ">=10.0.0"
   },
   "description": "A dynamic and interactive React portfolio showcasing professional experience as a DevOps & Cloud Engineer. Features modern JSON-based data architecture, responsive design, and seamless deployment with CI/CD pipelines.",
