   },
   "pnpm": {
      "overrides": {
         "@isaacs/brace-expansion": ">=5.0.1",
         "minimatch": ">=10.2.3",
         "js-yaml": ">=4.1.1",
         "ajv@<7": "~6.14.0",
         "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
         "undici": ">=7.24.0",
         "flatted": ">=3.4.0",
         "yaml": ">=2.8.3",
         "esbuild": ">=0.28.1"
      }
   }
